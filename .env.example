# ============================================================
# RAG Study Chatbot - Example environment configuration
# Copy this file to ".env" and fill in your real values.
#   copy .env.example .env        (Windows)
#   cp  .env.example .env         (macOS/Linux)
# ============================================================

# ---- LLM: Groq (free tier, fast) ----
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ---- Groq generation model ----
# llama-3.1-8b-instant = extremely fast + generous free tier.
# Upgrade to "llama-3.3-70b-versatile" for deeper answers if you need them.
GROQ_MODEL=llama-3.1-8b-instant

# ---- Embeddings: local sentence-transformers (no key needed) ----
# All-MiniLM-L6-v2 is fast, small (~90MB) and free.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ---- Vector database (Chroma) ----
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=study_notes

# ---- Where bundled default notes live ----
NOTES_DIR=pdf
UPLOAD_DIR=data/uploads

# ---- Retrieval tuning ----
# How many note chunks to feed the model when answering.
TOP_K=5
# Retrieve more candidates, then filter by similarity threshold before grading.
RETRIEVAL_CANDIDATE_K=20
# Max L2 distance (lower = better). Chunks above this are discarded as irrelevant.
RETRIEVAL_MAX_DISTANCE=1.09
# Token-based chunking (all-MiniLM-L6-v2 max = 256 tokens; keep chunks under that).
CHUNK_SIZE_TOKENS=220
CHUNK_OVERLAP_TOKENS=30
CHUNK_MIN_CHARS=80
CHUNK_MIN_TOKENS=25
# Log final prompts sent to the LLM (disable in production if noisy).
LOG_PROMPTS=true

# ---- Server ----
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# ---- Security ----
# Maximum upload size in bytes (15 MB). Protects the server from abuse.
MAX_UPLOAD_BYTES=15728640
# Maximum number of files a single user can upload in one request.
MAX_UPLOAD_FILES=10

# ---- Optional: keep-alive ping (for Render free tier) ----
# If set to "true", the server pings itself every 10 min so Render does not sleep.
KEEP_ALIVE_ENABLED=false
KEEP_ALIVE_URL=
